-- Función para añadir botones dinámicamente
local function NewButton(name, file, icon, isDiscord)
    local Btn = Instance.new("TextButton")
    Btn.Name = name:lower()
    Btn.BackgroundColor3 = C.SECONDARY
    Btn.Text = ""
    Btn.Parent = Content
    
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 10)
    local BStroke = Instance.new("UIStroke", Btn)
    BStroke.Thickness = 1.5
    BStroke.Color = Color3.fromRGB(40, 40, 50)

    local Lbl = Instance.new("TextLabel")
    Lbl.Size = UDim2.new(1, 0, 1, 0)
    Lbl.BackgroundTransparency = 1
    Lbl.Text = icon .. " " .. name
    Lbl.TextColor3 = C.TEXT
    Lbl.Font = Enum.Font.GothamSemibold
    Lbl.TextSize = 13
    Lbl.Parent = Btn

    -- Animaciones y Funciones
    Btn.MouseEnter:Connect(function()
        T:Create(Btn, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(35, 35, 55)}):Play()
        T:Create(BStroke, TweenInfo.new(0.3), {Color = C.ACCENT}):Play()
    end)
    Btn.MouseLeave:Connect(function()
        T:Create(Btn, TweenInfo.new(0.3), {BackgroundColor3 = C.SECONDARY}):Play()
        T:Create(BStroke, TweenInfo.new(0.3), {Color = Color3.fromRGB(40, 40, 50)}):Play()
    end)

    Btn.MouseButton1Click:Connect(function()
        if isDiscord then
            setclipboard(DISCORD_INVITE) -- Copia el link al portapapeles
            Lbl.Text = "✅ Link Copiado!"
            task.wait(2)
            Lbl.Text = icon .. " " .. name
        elseif file ~= "" then
            pcall(function() loadstring(game:HttpGet(BASE_URL .. file))() end)
        end
    end)
end

