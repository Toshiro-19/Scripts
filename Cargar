-- ================= LÓGICA DE BOTONES DINÁMICOS =================
local function NewButton(name, file, icon, isDiscord)
    local BtnContainer = Instance.new("Frame")
    BtnContainer.Name = name:lower()
    BtnContainer.BackgroundColor3 = THEME.Surface
    BtnContainer.Parent = Content
    
    Instance.new("UICorner", BtnContainer).CornerRadius = UDim.new(0, 8)
    local BStroke = Instance.new("UIStroke", BtnContainer)
    BStroke.Thickness = 1
    BStroke.Color = THEME.Border

    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(1, 0, 1, 0)
    Btn.BackgroundTransparency = 1
    Btn.Text = ""
    Btn.Parent = BtnContainer

    local Lbl = Instance.new("TextLabel")
    Lbl.Size = UDim2.new(1, -15, 1, 0)
    Lbl.Position = UDim2.new(0, 15, 0, 0)
    Lbl.BackgroundTransparency = 1
    Lbl.Text = icon .. "   " .. name
    Lbl.TextColor3 = THEME.Text
    Lbl.Font = Enum.Font.GothamMedium
    Lbl.TextSize = 13
    Lbl.TextXAlignment = Enum.TextXAlignment.Left
    Lbl.Parent = BtnContainer

    -- Animaciones de Vida (Hover y Click)
    Btn.MouseEnter:Connect(function()
        createTween(BtnContainer, {BackgroundColor3 = THEME.SurfaceHover}):Play()
        createTween(BStroke, {Color = THEME.Accent, Thickness = 1.5}):Play()
    end)
    
    Btn.MouseLeave:Connect(function()
        createTween(BtnContainer, {BackgroundColor3 = THEME.Surface}):Play()
        createTween(BStroke, {Color = THEME.Border, Thickness = 1}):Play()
    end)

    Btn.MouseButton1Down:Connect(function()
        createTween(BtnContainer, {Size = UDim2.new(0.92, 0, 0.92, 0)}):Play()
    end)

    Btn.MouseButton1Up:Connect(function()
        createTween(BtnContainer, {Size = UDim2.new(1, 0, 1, 0)}):Play()
    end)

    Btn.MouseButton1Click:Connect(function()
        if isDiscord then
            if setclipboard then
                setclipboard(DISCORD_INVITE)
                Lbl.Text = "✅ Link Copiado!"
                Lbl.TextColor3 = THEME.Accent
                task.delay(2, function()
                    if Lbl.Parent then
                        Lbl.Text = icon .. "   " .. name
                        Lbl.TextColor3 = THEME.Text
                    end
                end)
            end
        elseif file ~= "" then
            local originalText = Lbl.Text
            Lbl.Text = "⏳ Cargando..."
            Lbl.TextColor3 = THEME.Accent
            
            task.spawn(function()
                local success, err = pcall(function() 
                    loadstring(game:HttpGet(BASE_URL .. file))() 
                end)
                
                if success then
                    Lbl.Text = "✅ Ejecutado"
                    Lbl.TextColor3 = Color3.fromRGB(0, 255, 128)
                else
                    Lbl.Text = "❌ Error"
                    Lbl.TextColor3 = THEME.Danger
                    warn("Error en script: " .. tostring(err))
                end
                
                task.wait(1.5)
                if Lbl.Parent then
                    Lbl.Text = originalText
                    Lbl.TextColor3 = THEME.Text
                end
            end)
        end
    end)
end

